# splitroute configuration
# Changes take effect within ~30s. No restart needed.

# VPN interface detection (usually no need to change)
# auto = detect automatically | ppp = L2TP only | utun = IKEv2/WireGuard only
interface = auto

# Legacy proxy bridging (set to true if you want HTTP/SOCKS proxies set on the
# VPN network service for apps that follow it). Independent of the PAC layer
# below.
proxy = false
http_port = 7890
socks_port = 7891

# --- Browser split routing via PAC (v1.3+) ---
# Uncomment to customize; defaults are suitable for most setups.
#
#   pac_enabled = auto              # auto = on when any domain:/dns: line exists
#   pac_port = 7899
#   upstream_proxy =                # empty = auto-detect Clash (7890/7897/6152)
#   auto_set_system_proxy = true    # writes macOS auto-proxy URL on all services
#   manage_resolver = true          # manages /etc/resolver/<suffix> files

# === Routes (one IP or subnet per line) — any app's traffic to these goes via VPN ===
# 10.0.1.100
# 192.168.0.0/16

# === Hosts (browser + ssh/git/curl, all via VPN) ===
# `splitroute add git.company.com` writes one of these. The watch loop:
#   * adds it to the PAC DIRECT list (browser)
#   * auto-adds dns: <parent_suffix> auto (so DIRECT lookups use VPN DNS)
#   * resolves the hostname over VPN DNS and installs per-IP routes
#   * re-resolves periodically and updates routes if IPs change
# host: git.company.com
# host: bastion.company.com
#
# Add a fixed IP to pin the hostname via /etc/hosts and skip DNS entirely.
# Useful when the IP is stable and you'd rather not depend on VPN DNS at all.
# `splitroute add git.company.com 10.0.1.5` writes one of these.
# host: git.company.com 10.0.1.5
# host: bastion.company.com 10.0.1.6

# === Domains (PAC shExpMatch) — browser traffic to these goes via VPN ===
# Use this when you want a wildcard pattern. Requires DNS for these domains
# to be resolvable; see `dns:` below.
# domain: *.company.com
# domain: *.corp.internal
#
# `domain:` also accepts an IPv4 address or CIDR. Those entries generate PAC
# `isInNet` rules only — they do NOT add a macOS route. Use this when the VPN
# client already installs the route and you only need the browser to bypass the
# upstream proxy. If you also need non-browser traffic (SSH, curl) routed via
# VPN, add it as a plain `Routes` entry at the top of the file.
# domain: 10.0.1.5
# domain: 10.0.2.0/24

# === Internal DNS overrides (written to /etc/resolver/<suffix>) ===
# Format: dns: <suffix> [<nameserver-ip> | auto]
# 'auto' reads the nameserver from scutil --dns once VPN is connected.
# `splitroute add <hostname>` auto-adds the parent suffix here, so you usually
# don't need to manage these by hand.
# dns: company.com auto
# dns: corp.internal 10.0.0.53
